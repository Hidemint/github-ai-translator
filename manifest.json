{
  "manifest_version": 3,
  "name": "GitHub AI Translator",
  "version": "1.0.0",
  "description": "Переводит интерфейс GitHub на любой язык с помощью ИИ",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ]
}