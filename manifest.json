{
  "manifest_version": 3,
  "name": "GitHub AI Translator",
  "version": "1.2.0",
  "description": "Переводит интерфейс GitHub на русский с помощью локальной AI (Ollama) - бесконечно бесплатно",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://localhost:11434/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}