{
  "manifest_version": 3,
  "name": "GitHub AI Translator",
  "version": "2.0.0",
  "description": "Переводит интерфейс GitHub на любой язык с помощью Ollama AI (бесконечно бесплатно)",
  "permissions": ["activeTab", "storage", "scripting", "background"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon.png"
  }
}